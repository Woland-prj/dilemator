package pages

import "github.com/Woland-prj/dilemator/internal/view/layout"
import "github.com/Woland-prj/dilemator/internal/view/ui"

templ Platform(menu ui.MenuProps) {
	@layout.Base(layout.BaseProps{Title: "Platform page", Menu: menu, DrawUserBage: true}) {
		<div
			class="container mx-auto md:px-20"
			hx-get="/components/dilemma/dashboard"
			hx-swap="innerHTML"
			hx-trigger="load"
		></div>
	}
}
