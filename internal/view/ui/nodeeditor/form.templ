package nodeeditor

import "github.com/Woland-prj/dilemator/internal/domain/entity/dilemma_entity"
import "github.com/google/uuid"
import "fmt"

func getURL(isRoot bool, isUpdate bool, did uuid.UUID, id uuid.UUID) string {
	if isRoot {
		if isUpdate {
			return fmt.Sprintf("/api/dilemma?did=%s", did.String())
		}
		return "/api/dilemma"
	} else {
		if isUpdate {
			return fmt.Sprintf("/api/dilemma/node?did=%s&nid=%s", did.String(), id.String())
		}
		return fmt.Sprintf("/api/dilemma/node?did=%s&pid=%s", did.String(), id.String())
	}
}

templ ScenarioForm(dilemma dilemma_entity.Dilemma, node dilemma_entity.DilemmaNode, isNew bool) {
	<script src="/assets/scenario_form_interact.js"></script>
	<form
		class="flex flex-col h-full w-full gap-y-4"
		id="editor-form"
		if isNew {
			hx-post={ getURL(node.ParentID == uuid.Nil, false, dilemma.ID, node.ParentID) }
		} else {
			hx-put={ getURL(node.ParentID == uuid.Nil, true, dilemma.ID, node.ID) }
		}
		enctype="multipart/form-data"
		hx-trigger="submit"
		hx-target="#content-container"
	>
		if (node.ParentID == uuid.Nil) {
			<input
				type="text"
				placeholder="Topic of your dilemma..."
				class="input w-full"
				name="topic"
				value={ dilemma.Topic }
			/>
		} else {
			<h2 class="text-2xl font-semibold text-primary-content">
				{ dilemma.Topic }
			</h2>
		}
		<fieldset class="fieldset flex flex-col bg-base-300 border-base-300 rounded-box w-full h-full border p-4">
			<legend class="fieldset-legend">Scenario editing</legend>
			<label class="label">Scenario name</label>
			<input
				type="text"
				value={ node.Name }
				class="input w-full"
				name="name"
				placeholder="Name of your scenario"
			/>
			<label class="label">Scenario description</label>
			<textarea
				class="textarea w-full flex-1 resize-none"
				name="value"
				placeholder="Describe what's happening..."
			>{ node.Value }</textarea>
			<label class="label">Scenario image</label>
			<input
				type="file"
				name="image"
				class="file-input w-full"
			/>
			<button
				type="submit"
				class="btn btn-neutral mt-4 btn-disabled"
			>
				Save scenario
			</button>
		</fieldset>
	</form>
}
